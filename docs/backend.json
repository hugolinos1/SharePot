
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user profile within the application, storing basic information, administrative status, and the projects they are associated with. This entity is linked to an external authentication system (Firebase).",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity, corresponding to the external authentication system's user ID."
        },
        "name": {
          "type": "string",
          "description": "The display name of the user."
        },
        "isAdmin": {
          "type": "boolean",
          "description": "Indicates whether the user has administrative privileges."
        },
        "email": {
          "type": "string",
          "description": "User email address."
        },
        "avatarUrl": {
          "type": "string",
          "description": "Optional URL to the user's avatar image.",
          "format": "uri"
        }
      },
      "required": [
        "id",
        "name",
        "isAdmin",
        "email"
      ]
    },
    "AppSetting": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "AppSetting",
      "type": "object",
      "description": "Global application configuration settings.",
      "properties": {
        "apiKey": {
          "type": "string",
          "description": "API Key for external services (e.g., OpenRouter)."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Project": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Project",
      "type": "object",
      "description": "Represents a project to which expenses can be linked.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "ownerId": {
          "type": "string"
        },
        "members": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "Expense": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Expense",
      "type": "object",
      "description": "Financial transaction within a project.",
      "properties": {
        "id": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "currency": {
          "type": "string"
        }
      }
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": {
            "$ref": "#/backend/entities/UserProfile"
          },
          "description": "User profiles."
        }
      },
      {
        "path": "/settings/{settingId}",
        "definition": {
          "entityName": "AppSetting",
          "schema": {
            "$ref": "#/backend/entities/AppSetting"
          },
          "description": "Global settings like API keys."
        }
      },
      {
        "path": "/projects/{projectId}",
        "definition": {
          "entityName": "Project",
          "schema": {
            "$ref": "#/backend/entities/Project"
          },
          "description": "Shared projects."
        }
      },
      {
        "path": "/expenses/{expenseId}",
        "definition": {
          "entityName": "Expense",
          "schema": {
            "$ref": "#/backend/entities/Expense"
          },
          "description": "Individual expenses."
        }
      }
    ]
  }
}
